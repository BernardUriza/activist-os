{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BernardUriza/activist-os/contracts/safety_verdict.schema.json",
  "title": "SafetyVerdict",
  "description": "Output of SAFETY agent. Veto power: nothing reaches OUTREACH without status=approved.",
  "type": "object",
  "required": [
    "plan_revision",
    "status",
    "checks",
    "issued_at"
  ],
  "properties": {
    "plan_revision": {
      "type": "integer"
    },
    "status": {
      "enum": [
        "approved",
        "needs_revision",
        "blocked"
      ]
    },
    "checks": {
      "type": "object",
      "required": [
        "defamation",
        "doxxing",
        "harassment",
        "unsupported_claims",
        "escalation"
      ],
      "properties": {
        "defamation": {
          "enum": [
            "pass",
            "fail",
            "warn"
          ]
        },
        "doxxing": {
          "enum": [
            "pass",
            "fail",
            "warn"
          ]
        },
        "harassment": {
          "enum": [
            "pass",
            "fail",
            "warn"
          ]
        },
        "unsupported_claims": {
          "enum": [
            "pass",
            "fail",
            "warn"
          ]
        },
        "escalation": {
          "enum": [
            "pass",
            "fail",
            "warn"
          ]
        }
      }
    },
    "blocked_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target",
          "reason"
        ],
        "properties": {
          "target": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
