{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BernardUriza/activist-os/contracts/audit_event.schema.json",
  "title": "AuditEvent",
  "description": "Immutable audit log entry. Every handoff, veto, approval, and error is recorded. The full audit trail ships inside CampaignPacket. Governance that only shows its approvals is marketing.",
  "type": "object",
  "required": [
    "event_id",
    "run_id",
    "event_type",
    "agent",
    "occurred_at"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "UUID"
    },
    "run_id": {
      "type": "string",
      "description": "Matches WorkflowRun.run_id"
    },
    "event_type": {
      "enum": [
        "workflow_started",
        "agent_started",
        "agent_completed",
        "handoff_sent",
        "handoff_received",
        "safety_veto",
        "safety_approved",
        "safety_revision_requested",
        "campaign_rewritten",
        "workflow_completed",
        "workflow_blocked",
        "error"
      ]
    },
    "agent": {
      "enum": [
        "evidence",
        "campaign",
        "safety",
        "outreach",
        "coordinator",
        "reporter",
        "system"
      ]
    },
    "summary": {
      "type": "string",
      "description": "Human-readable one-line description of what happened"
    },
    "detail": {
      "type": "object",
      "description": "Optional structured detail — for veto events: the blocked_items; for handoffs: from/to/type"
    },
    "handoff_ref": {
      "type": "string",
      "description": "AgentHandoff.handoff_id if this event tracks a specific handoff"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
