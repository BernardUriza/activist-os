{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BernardUriza/activist-os/contracts/workflow_run.schema.json",
  "title": "WorkflowRun",
  "description": "Mutable state envelope for a full activist-os workflow run. Carried through the transport layer so every agent can read current status and prior outputs.",
  "type": "object",
  "required": [
    "run_id",
    "concern",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "UUID — matches UserConcern.id"
    },
    "concern": {
      "$ref": "user_concern.schema.json",
      "description": "The original concern that started this run"
    },
    "status": {
      "enum": [
        "pending",
        "evidence_running",
        "campaign_running",
        "safety_review",
        "safety_revision",
        "outreach_running",
        "coordinator_running",
        "reporter_running",
        "completed",
        "blocked",
        "error"
      ]
    },
    "veto_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Number of times Safety has vetoed in this run. Visible in the audit trail."
    },
    "evidence_brief": {
      "$ref": "evidence_brief.schema.json"
    },
    "campaign_plan": {
      "$ref": "campaign_plan.schema.json"
    },
    "safety_verdict": {
      "$ref": "safety_verdict.schema.json"
    },
    "outreach_pack": {
      "$ref": "outreach_pack.schema.json"
    },
    "task_board": {
      "$ref": "task_board.schema.json"
    },
    "campaign_packet": {
      "$ref": "campaign_packet.schema.json"
    },
    "audit_events": {
      "type": "array",
      "items": {
        "$ref": "audit_event.schema.json"
      },
      "description": "Ordered log of every handoff, veto, and decision in this run"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "error": {
      "type": "string",
      "description": "Human-readable error message if status == error"
    }
  }
}
