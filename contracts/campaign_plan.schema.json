{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BernardUriza/activist-os/contracts/campaign_plan.schema.json",
  "title": "CampaignPlan",
  "description": "Output of CAMPAIGN agent. Every narrative element references the evidence it stands on.",
  "type": "object",
  "required": [
    "objective",
    "narrative",
    "audience",
    "actions",
    "evidence_refs",
    "revision"
  ],
  "properties": {
    "objective": {
      "type": "string"
    },
    "narrative": {
      "type": "string"
    },
    "audience": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "description",
          "evidence_refs"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Claim ids from the evidence_brief this action relies on"
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "description": "Increments on each SAFETY-driven revision loop"
    }
  }
}
