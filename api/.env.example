# Activist OS API — example env. Copy to .env (gitignored) and fill locally.
# NEVER commit real credentials. Secret files live OUTSIDE the repo.

# Transport: "local" (default, in-memory) or "band" (real Band coordination).
TRANSPORT=local

# --- Real Band path (opt-in) — see docs/BAND_REAL_SMOKE.md ------------------
# Only needed when TRANSPORT=band or for the opt-in real-Band smoke test.
# RUN_BAND_SMOKE=1
# BAND_REST_URL=https://app.band.ai
# AGENT_CONFIG_PATH=/abs/path/to/agent_config.yaml   # holds secrets — keep outside the repo

# --- Template chat surface (python-bot) ------------------------------------
# APP_REQUEST_TEXT_MAX_CHARS=12000
