# Activist OS API — environment template.
# Copy to api/.env for local dev. In containers, set real env vars instead
# (az containerapp secret set — never bake secrets into the image).

# ── Transport ────────────────────────────────────────────────────────
# local = in-process LocalTransport (default) · band = real Band rooms
TRANSPORT=local

# ── Band (required when TRANSPORT=band) ──────────────────────────────
# Always pin the REST base URL — the SDK default points at a dead dev host.
BAND_REST_URL=https://app.band.ai
# Agents beyond the 5-participant room cap run as virtual/backend agents.
BAND_VIRTUAL_AGENTS=reporter
# Per-agent UUIDs + API keys. Defaults to api/agent_config.yaml (gitignored).
AGENT_CONFIG_PATH=

# ── Env file override (containers/CI) ────────────────────────────────
# Band agent processes resolve their env through band_agents/env.py:
# this var > api/.env next to the package > find_dotenv from cwd.
ACTIVIST_OS_ENV_FILE=

# ── Model access (Band agent processes) ──────────────────────────────
ANTHROPIC_AUTH_TOKEN=
